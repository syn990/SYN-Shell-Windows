# Per-machine generated state -- never portable, regenerated by
# Resolve-Tools.ps1 / Apply-SynTheme.ps1 on whatever machine runs this.
.state/

# The four SYN-OS-<name>.png files are the actual SYN-OS branding assets
# (copied from the parent project) and are tracked. Anything else dropped
# here (personal wallpapers, other images) stays untracked.
assets/wallpaper/*
!assets/wallpaper/.gitkeep
!assets/wallpaper/SYN-OS-RED.png
!assets/wallpaper/SYN-OS-BLUE.png
!assets/wallpaper/SYN-OS-GREEN.png
!assets/wallpaper/SYN-OS-PURPLE.png
